## Get latest from https://github.com/github/gitignore

# ===================================================================
# C++ / C build artifacts
# ===================================================================

# Compiled Object files
*.o
*.obj
*.slo
*.lo

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Compiled Static libraries
*.a
*.lib
*.lai
*.la

# Executables
*.exe
*.out
*.app

# Debugger Files
*.pdb
*.ilk
*.d
*.dwo
*.mod
*.smod
*.idb


# ===================================================================
# CMake generated files
# ===================================================================
CMakeCache.txt
CMakeLists.txt.user
CMakeUserPresets.json
CMakeFiles/
CMakeScripts/
CTestTestfile.cmake
_deps/
Testing/
Makefile
cmake_install.cmake
compile_commands.json
install_manifest.txt


# ===================================================================
# Build output directories
# ===================================================================

# Common CMake build directory names
[Bb]uild/
build/
cmake-build-*/

# Project-specific output directory
/out/
/.idea/
/.vs/
.vs/
/cmake-build-debug/
/vcpkg/
/cmake/
appinfo.aps
.gitattributes
.clang-format


# ===================================================================
# Project-specific ignores
# ===================================================================
FIGIMappingTool/archive/
FIGIMappingTool/tests
FIGIMappingTool/core/Request.h
FIGIMappingTool/core/Request.cpp
FIGIMappingTool/utilities/Timer.h
FIGIMappingTool/utilities/Timer.cpp

# ===================================================================
# Project-specific NOT ignores
# ===================================================================
!/external/**/*.lib
!/external/**/*.dll